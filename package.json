{
  "name": "cafeflow-erp-pos",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "db:types": "supabase gen types typescript --local > src/lib/supabase/database.types.ts",
    "db:reset": "supabase db reset",
    "db:reset-demo": "supabase db reset && npm run db:seed-auth",
    "db:push": "supabase db push",
    "db:seed-auth": "node scripts/seed-auth.mjs",
    "smoke:check": "node scripts/smoke-check.mjs",
    "verify:post-006": "node scripts/verify-post-006.mjs",
